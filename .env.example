# Public origin used for canonical URLs, sitemaps and social metadata
NEXT_PUBLIC_SITE_URL=https://visit-nairobi.example

# Auth (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
# Local dev only: echoes the magic-link URL back in the /api/auth/request response so you can
# sign in without a real email provider configured. Never set this in production — anyone who
# can call the endpoint would get a working sign-in link for any email address.
AUTH_DEV_ECHO_LINKS=

# Transactional email provider
EMAIL_API_URL=
EMAIL_API_KEY=
EMAIL_FROM=
STAFF_NOTIFICATION_EMAIL=
ADMIN_EMAILS=

# Configurable providers
NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_MAP_TOKEN=
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_CONSENT_MANAGER=

# Security and operations
UPLOAD_MAX_MB=10
ALLOWED_UPLOAD_TYPES=application/pdf,image/jpeg,image/png
DATA_RETENTION_DAYS=730
BACKUP_BUCKET=
